{
  "name": "omniplot-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint --ext .ts,.vue src",
    "lint:fix": "eslint --ext .ts,.vue src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json,css}\"",
    "gen:openapi": "cd ../backend && .venv/bin/python -c \"import json; from pen_plotter.main import app; open('openapi.json','w').write(json.dumps(app.openapi(), indent=2))\"",
    "gen:types": "openapi-typescript ../backend/openapi.json -o src/domain/api-types.ts"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "axios": "^1.7.7",
    "dompurify": "^3.4.5",
    "pinia": "^3.0.4",
    "svg-pan-zoom": "^3.6.2",
    "vue": "^3.5.12",
    "vue-i18n": "^10.0.8",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "happy-dom": "^20.9.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
